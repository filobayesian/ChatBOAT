<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="chatboat_uvms">

  <!-- Composite UVMS: GIRONA500 + ECA 5E + Gripper -->

  <xacro:include filename="$(find chatboat_description)/urdf/girona500.urdf.xacro"/>
  <xacro:include filename="$(find chatboat_description)/urdf/eca5e.urdf.xacro"/>
  <xacro:include filename="$(find chatboat_description)/urdf/gripper.urdf.xacro"/>

  <xacro:arg name="namespace" default="girona500"/>

  <!-- World frame (NED) -->
  <link name="world"/>
  <joint name="world_to_base" type="floating">
    <parent link="world"/>
    <child link="$(arg namespace)/base_link"/>
  </joint>

  <!-- Instantiate vehicle -->
  <xacro:girona500 namespace="$(arg namespace)"/>

  <!-- Instantiate arm (mounted at front-bottom of vehicle) -->
  <xacro:eca5e parent="$(arg namespace)/base_link" namespace="$(arg namespace)"/>

  <!-- Instantiate gripper (at end of arm) -->
  <xacro:gripper parent="arm_link4"/>

</robot>

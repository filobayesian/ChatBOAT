<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="chatboat_uvms">

  <!-- Composite UVMS: BlueROV2 Heavy + Reach Alpha 5 + Gripper -->

  <xacro:include filename="$(find chatboat_description)/urdf/bluerov2.urdf.xacro"/>
  <xacro:include filename="$(find chatboat_description)/urdf/alpha5.urdf.xacro"/>
  <xacro:include filename="$(find chatboat_description)/urdf/gripper.urdf.xacro"/>

  <xacro:arg name="namespace" default="chatboat"/>

  <!-- World frame (NED) -->
  <link name="world"/>
  <joint name="world_to_base" type="floating">
    <parent link="world"/>
    <child link="$(arg namespace)/base_link"/>
  </joint>

  <!-- Instantiate vehicle -->
  <xacro:bluerov2 namespace="$(arg namespace)"/>

  <!-- Instantiate arm (mounted at front of vehicle) -->
  <xacro:alpha5 parent="$(arg namespace)/base_link" namespace="$(arg namespace)"/>

  <!-- Instantiate gripper (at end of arm) -->
  <xacro:gripper parent="arm_wrist"/>

</robot>

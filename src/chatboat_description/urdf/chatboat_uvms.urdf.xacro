<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="chatboat_uvms">

  <!-- BlueROV2 Heavy only (no arm) — stability test -->

  <xacro:include filename="$(find chatboat_description)/urdf/bluerov2.urdf.xacro"/>

  <xacro:arg name="namespace" default="chatboat"/>

  <!-- World frame (NED) -->
  <link name="world"/>
  <joint name="world_to_base" type="floating">
    <parent link="world"/>
    <child link="$(arg namespace)/base_link"/>
  </joint>

  <!-- Instantiate vehicle -->
  <xacro:bluerov2 namespace="$(arg namespace)"/>

</robot>

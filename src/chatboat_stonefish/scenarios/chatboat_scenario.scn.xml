<?xml version="1.0"?>
<!--
  ChatBOAT UVMS Scenario: BlueROV2 Heavy + Reach Alpha 5 arm + magnetic gripper
  Stonefish simulator scenario file
-->
<scenario>
  <environment>
    <ned latitude="41.7" longitude="2.8"/>
    <ocean>
      <water density="1025.0" jerlov="0.2"/>
      <waves height="0.0"/>
      <particles enabled="true"/>
    </ocean>
    <atmosphere>
      <sun azimuth="180.0" elevation="60.0"/>
    </atmosphere>
  </environment>

  <materials>
    <material name="Neutral" density="1000.0" restitution="0.5"/>
    <material name="Rock" density="3000.0" restitution="0.8"/>
    <material name="Fiberglass" density="1500.0" restitution="0.3"/>
    <material name="Aluminium" density="2710.0" restitution="0.5"/>
    <material name="Steel" density="7800.0" restitution="0.4"/>
    <material name="Sand" density="2650.0" restitution="0.2"/>
    <material name="Ferromagnetic" density="7800.0" restitution="0.4"/>
    <material name="PermanentMagnet" density="7500.0" restitution="0.4"/>
    <friction_table>
      <friction material1="Neutral" material2="Neutral" static="0.5" dynamic="0.2"/>
      <friction material1="Neutral" material2="Rock" static="0.2" dynamic="0.1"/>
      <friction material1="Neutral" material2="Fiberglass" static="0.5" dynamic="0.2"/>
      <friction material1="Neutral" material2="Aluminium" static="0.1" dynamic="0.02"/>
      <friction material1="Neutral" material2="Steel" static="0.3" dynamic="0.1"/>
      <friction material1="Neutral" material2="Ferromagnetic" static="0.3" dynamic="0.1"/>
      <friction material1="Rock" material2="Rock" static="0.9" dynamic="0.7"/>
      <friction material1="Fiberglass" material2="Fiberglass" static="0.5" dynamic="0.2"/>
      <friction material1="Aluminium" material2="Aluminium" static="0.8" dynamic="0.5"/>
      <friction material1="Aluminium" material2="Ferromagnetic" static="0.9" dynamic="0.7"/>
      <friction material1="Ferromagnetic" material2="Ferromagnetic" static="0.8" dynamic="0.6"/>
      <friction material1="Sand" material2="Ferromagnetic" static="0.6" dynamic="0.4"/>
    </friction_table>
  </materials>

  <looks>
    <look name="seabed" gray="0.6" roughness="0.9"/>
    <look name="br2" gray="1.0" roughness="0.4" metalness="0.5" texture="bluerov2/br2.png"/>
    <look name="black" gray="0.05" roughness="0.2"/>
    <look name="blue" rgb="0.0 0.5 1.0" roughness="0.3"/>
    <look name="red" gray="0.5" roughness="0.5" rgb="1.0 0.1 0.1"/>
    <look name="green" gray="0.5" roughness="0.5" rgb="0.1 0.8 0.1"/>
    <look name="arm_dark" gray="0.8" roughness="0.3" rgb="1.0 1.0 0.0"/>
    <look name="arm_orange" gray="0.8" roughness="0.3" rgb="1.0 0.4 0.0"/>
    <look name="None" gray="0.0" roughness="0.0"/>
  </looks>

  <!-- Seafloor at 5m depth -->
  <static name="seafloor" type="box">
    <dimensions xyz="100.0 100.0 1.0"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="Sand"/>
    <look name="seabed"/>
    <world_transform xyz="0.0 0.0 5.5" rpy="0.0 0.0 0.0"/>
  </static>

  <!-- Manipulation targets -->
  <dynamic name="cube_a" type="box">
    <dimensions xyz="0.1 0.1 0.1"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="Ferromagnetic"/>
    <mass value="2.0"/>
    <look name="red"/>
    <world_transform xyz="1.0 0.0 4.95" rpy="0.0 0.0 0.0"/>
  </dynamic>

  <dynamic name="cube_b" type="box">
    <dimensions xyz="0.1 0.1 0.1"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="Ferromagnetic"/>
    <mass value="2.0"/>
    <look name="green"/>
    <world_transform xyz="2.0 0.0 4.95" rpy="0.0 0.0 0.0"/>
  </dynamic>

  <!-- ================================================================== -->
  <!-- ROBOT: BlueROV2 Heavy + Reach Alpha 5 + Magnetic Gripper           -->
  <!-- ================================================================== -->
  <robot name="chatboat" fixed="false" self_collisions="false">

    <!-- ============================================================== -->
    <!-- VEHICLE BODY: BlueROV2 Heavy compound hull                     -->
    <!-- ============================================================== -->
    <base_link name="base_link" type="compound" physics="submerged">
      <!-- Main hull (visual: detailed mesh, physical: simplified mesh) -->
      <external_part name="HullBottom" type="model" physics="submerged" buoyant="false">
        <physical>
          <mesh filename="bluerov2/bluerov2_phy.obj" scale="1.0"/>
          <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
          <thickness value="0.005"/>
        </physical>
        <visual>
          <mesh filename="bluerov2/bluerov2.obj" scale="1.0"/>
          <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
        </visual>
        <material name="Fiberglass"/>
        <mass value="6.0"/>
        <look name="br2"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      </external_part>

      <!-- Wings/frame (visual: detailed, physical: simplified ring) -->
      <external_part name="HeavyFit" type="model" physics="submerged" buoyant="false">
        <physical>
          <mesh filename="bluerov2/bluerov2_ring.obj" scale="1.0"/>
          <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.03"/>
          <thickness value="0.005"/>
        </physical>
        <visual>
          <mesh filename="bluerov2/bluerov2_wings.obj" scale="1.0"/>
          <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
        </visual>
        <material name="Fiberglass"/>
        <mass value="3.0"/>
        <look name="black"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      </external_part>

      <!-- Buoyancy boxes (4 corners) -->
      <internal_part name="BackLeft" type="box" physics="submerged" buoyant="true">
        <dimensions xyz="0.2 0.15 0.091"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Neutral"/>
        <look name="None"/>
        <mass value="0.025"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="-0.1 -0.1 -0.06"/>
      </internal_part>
      <internal_part name="BackRight" type="box" physics="submerged" buoyant="true">
        <dimensions xyz="0.2 0.15 0.091"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Neutral"/>
        <look name="None"/>
        <mass value="0.025"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="-0.1 0.1 -0.06"/>
      </internal_part>
      <internal_part name="FrontLeft" type="box" physics="submerged" buoyant="true">
        <dimensions xyz="0.2 0.15 0.091"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Neutral"/>
        <look name="None"/>
        <mass value="0.025"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="0.09 -0.1 -0.06"/>
      </internal_part>
      <internal_part name="FrontRight" type="box" physics="submerged" buoyant="true">
        <dimensions xyz="0.2 0.15 0.091"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Neutral"/>
        <look name="None"/>
        <mass value="0.025"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="0.09 0.1 -0.06"/>
      </internal_part>

      <!-- Ballast weights (tuned for near-neutral buoyancy) -->
      <!-- Buoyancy budget: 4 boxes × (0.2×0.15×0.091) × 1025 ≈ 11.2 kg -->
      <!-- Mass budget: hull 9.0 + boxes 0.1 + arm ~1.7 + weights → target ~11.2 -->
      <internal_part name="WeightCenter" type="sphere" physics="submerged" buoyant="false">
        <dimensions radius="0.01"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Steel"/>
        <look name="black"/>
        <mass value="0.3"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="-0.05 0.0 0.22"/>
      </internal_part>
      <internal_part name="WeightLeft" type="sphere" physics="submerged" buoyant="false">
        <dimensions radius="0.01"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Steel"/>
        <look name="black"/>
        <mass value="0.15"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="0.0 -0.075 0.22"/>
      </internal_part>
      <internal_part name="WeightRight" type="sphere" physics="submerged" buoyant="false">
        <dimensions radius="0.01"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="Steel"/>
        <look name="black"/>
        <mass value="0.15"/>
        <compound_transform rpy="0.0 0.0 0.0" xyz="0.0 0.075 0.22"/>
      </internal_part>
    </base_link>

    <!-- ============================================================== -->
    <!-- MANIPULATOR ARM: Reach Alpha 5 (4 revolute DOF + gripper)      -->
    <!-- Cylinder primitives (known working baseline)                   -->
    <!-- ============================================================== -->

    <!-- Arm base adapter (URDF: base_link, RS1-1010) -->
    <link name="arm_base" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.035" height="0.130"/>
      <origin xyz="-0.055 0.0 0.0" rpy="0.0 1.5708 0.0"/>
      <material name="Aluminium"/>
      <mass value="0.234"/>
      <look name="arm_dark"/>
    </link>
    <joint name="arm_base_joint" type="fixed">
      <parent name="base_link"/>
      <child name="arm_base"/>
      <origin xyz="0.18 0.0 0.08" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- Inline actuator (URDF: m3_inline_link, M3-INLINE) -->
    <link name="arm_inline" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.035" height="0.150"/>
      <origin xyz="-0.055 0.0 0.0" rpy="0.0 1.5708 0.0"/>
      <material name="Aluminium"/>
      <mass value="0.341"/>
      <look name="arm_dark"/>
    </link>
    <joint name="arm_inline_joint" type="fixed">
      <parent name="arm_base"/>
      <child name="arm_inline"/>
      <origin xyz="0.124 0.004 0.0" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- Joint E connector (URDF: m2_1_1_link, M2-1-1) -->
    <link name="arm_connector" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.035" height="0.040"/>
      <origin xyz="0.0 0.0 0.020" rpy="0.0 0.0 0.0"/>
      <material name="Aluminium"/>
      <mass value="0.194"/>
      <look name="arm_orange"/>
    </link>
    <joint name="axis_e" type="revolute">
      <parent name="arm_inline"/>
      <child name="arm_connector"/>
      <origin xyz="0.0 0.0 0.014" rpy="0.0 0.0 0.0"/>
      <axis xyz="0.0 0.0 1.0"/>
      <limits min="0.0" max="6.10"/>
    </joint>

    <!-- Main arm segment (URDF: m2_link, M2) — longest link -->
    <link name="arm_upper" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.035" height="0.145"/>
      <origin xyz="-0.02 0.0 -0.0725" rpy="0.0 0.0 0.0"/>
      <material name="Aluminium"/>
      <mass value="0.429"/>
      <look name="arm_orange"/>
    </link>
    <joint name="axis_d" type="revolute">
      <parent name="arm_connector"/>
      <child name="arm_upper"/>
      <origin xyz="-0.02 0.0 0.033" rpy="0.0 0.0 0.0"/>
      <axis xyz="0.0 1.0 0.0"/>
      <limits min="-3.49" max="3.49"/>
    </joint>

    <!-- Elbow connector (URDF: m2_1_3_link, M2-1-3) -->
    <link name="arm_elbow" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.035" height="0.040"/>
      <origin xyz="0.02 0.0 0.020" rpy="0.0 0.0 0.0"/>
      <material name="Aluminium"/>
      <mass value="0.115"/>
      <look name="arm_orange"/>
    </link>
    <joint name="axis_c" type="revolute">
      <parent name="arm_upper"/>
      <child name="arm_elbow"/>
      <origin xyz="-0.04 0.0 -0.1453" rpy="0.0 0.0 3.14159"/>
      <axis xyz="0.0 1.0 0.0"/>
      <limits min="0.0" max="3.22"/>
    </joint>

    <!-- Wrist (URDF: m1_link, M1) -->
    <link name="arm_wrist" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.035" height="0.100"/>
      <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
      <material name="Aluminium"/>
      <mass value="0.200"/>
      <look name="arm_dark"/>
    </link>
    <joint name="axis_b" type="revolute">
      <parent name="arm_elbow"/>
      <child name="arm_wrist"/>
      <origin xyz="0.02 0.0 0.033" rpy="0.0 0.0 2.09439"/>
      <axis xyz="0.0 0.0 -1.0"/>
      <limits min="0.0" max="3.22"/>
    </joint>

    <!-- Magnetic gripper tip -->
    <link name="gripper_tip" type="sphere" physics="submerged" buoyant="true">
      <dimensions radius="0.035"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <material name="PermanentMagnet"/>
      <mass value="0.15"/>
      <look name="red"/>
    </link>
    <joint name="gripper_joint" type="fixed">
      <parent name="arm_wrist"/>
      <child name="gripper_tip"/>
      <origin xyz="0.0 0.0 0.14" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- End-effector control frame -->
    <link name="ee_frame" type="sphere" physics="surface" buoyant="false">
      <dimensions radius="0.005"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <material name="Neutral"/>
      <mass value="0.001"/>
      <look name="red"/>
    </link>
    <joint name="ee_frame_joint" type="fixed">
      <parent name="gripper_tip"/>
      <child name="ee_frame"/>
      <origin xyz="0.0 0.0 0.025" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- ============================================================== -->
    <!-- THRUSTERS: BlueROV2 Heavy vectored 6-DOF (8 thrusters)         -->
    <!-- ============================================================== -->

    <!-- Horizontal thrusters (surge/sway/yaw) -->
    <actuator name="ThrusterFR" type="thruster">
      <link name="base_link"/>
      <origin xyz="0.1355 0.1 0.0725" rpy="0.0 0.0 -0.7854"/>
      <specs max_setpoint="1000.0" inverted="true"/>
      <propeller diameter="0.076" right="true">
        <mesh filename="bluerov2/ccw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>
    <actuator name="ThrusterFL" type="thruster">
      <link name="base_link"/>
      <origin xyz="0.1355 -0.1 0.0725" rpy="0.0 0.0 0.7854"/>
      <specs max_setpoint="1000.0" inverted="true"/>
      <propeller diameter="0.076" right="true">
        <mesh filename="bluerov2/ccw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>
    <actuator name="ThrusterBR" type="thruster">
      <link name="base_link"/>
      <origin xyz="-0.1475 0.1 0.0725" rpy="0.0 0.0 -2.3562"/>
      <specs max_setpoint="1000.0" inverted="false"/>
      <propeller diameter="0.076" right="false">
        <mesh filename="bluerov2/cw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>
    <actuator name="ThrusterBL" type="thruster">
      <link name="base_link"/>
      <origin xyz="-0.1475 -0.1 0.0725" rpy="0.0 0.0 2.3562"/>
      <specs max_setpoint="1000.0" inverted="false"/>
      <propeller diameter="0.076" right="false">
        <mesh filename="bluerov2/cw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>

    <!-- Vertical thrusters (heave/roll/pitch) -->
    <actuator name="ThrusterDFR" type="thruster">
      <link name="base_link"/>
      <origin xyz="0.12 0.218 0.0" rpy="0.0 -1.5708 0.0"/>
      <specs max_setpoint="1000.0" inverted="false"/>
      <propeller diameter="0.076" right="true">
        <mesh filename="bluerov2/cw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>
    <actuator name="ThrusterDFL" type="thruster">
      <link name="base_link"/>
      <origin xyz="0.12 -0.218 0.0" rpy="0.0 -1.5708 0.0"/>
      <specs max_setpoint="1000.0" inverted="true"/>
      <propeller diameter="0.076" right="false">
        <mesh filename="bluerov2/ccw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>
    <actuator name="ThrusterDBR" type="thruster">
      <link name="base_link"/>
      <origin xyz="-0.12 0.218 0.0" rpy="0.0 -1.5708 0.0"/>
      <specs max_setpoint="1000.0" inverted="true"/>
      <propeller diameter="0.076" right="false">
        <mesh filename="bluerov2/ccw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>
    <actuator name="ThrusterDBL" type="thruster">
      <link name="base_link"/>
      <origin xyz="-0.12 -0.218 0.0" rpy="0.0 -1.5708 0.0"/>
      <specs max_setpoint="1000.0" inverted="false"/>
      <propeller diameter="0.076" right="true">
        <mesh filename="bluerov2/cw.obj" scale="1.0"/>
        <material name="Neutral"/>
        <look name="blue"/>
      </propeller>
      <rotor_dynamics type="first_order">
        <time_constant value="0.1"/>
      </rotor_dynamics>
      <thrust_model type="quadratic">
        <thrust_coeff value="0.167"/>
      </thrust_model>
    </actuator>

    <!-- ============================================================== -->
    <!-- ARM SERVO ACTUATORS                                            -->
    <!-- ============================================================== -->
    <actuator name="servo_e" type="servo">
      <joint name="axis_e"/>
      <controller position_gain="2.0" velocity_gain="3.0" max_torque="3.0"/>
      <initial position="2.64"/>
    </actuator>
    <actuator name="servo_d" type="servo">
      <joint name="axis_d"/>
      <controller position_gain="2.0" velocity_gain="3.0" max_torque="3.0"/>
      <initial position="2.22"/>
    </actuator>
    <actuator name="servo_c" type="servo">
      <joint name="axis_c"/>
      <controller position_gain="2.0" velocity_gain="3.0" max_torque="3.0"/>
      <initial position="2.64"/>
    </actuator>
    <actuator name="servo_b" type="servo">
      <joint name="axis_b"/>
      <controller position_gain="2.0" velocity_gain="3.0" max_torque="3.0"/>
      <initial position="0.04"/>
    </actuator>


    <!-- ============================================================== -->
    <!-- SENSORS                                                        -->
    <!-- ============================================================== -->

    <!-- Navigation sensors on vehicle body -->
    <sensor name="odometry" type="odometry" rate="50.0">
      <link name="base_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <noise position="0.01" velocity="0.005" angle="0.005" angular_velocity="0.002"/>
      <ros_publisher topic="/chatboat/odometry"/>
    </sensor>

    <sensor name="imu" type="imu" rate="100.0">
      <link name="base_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <noise angle="0.01" angular_velocity="0.001" linear_acceleration="0.01"/>
      <ros_publisher topic="/chatboat/imu"/>
    </sensor>

    <sensor name="pressure" type="pressure" rate="10.0">
      <link name="base_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <noise pressure="100.0"/>
      <ros_publisher topic="/chatboat/pressure"/>
    </sensor>

    <sensor name="dvl" type="dvl" rate="10.0">
      <link name="base_link"/>
      <origin xyz="0.0 0.0 0.20" rpy="3.1416 0.0 0.0"/>
      <specs beam_angle="30.0"/>
      <range velocity="9.0 9.0 9.0" altitude_min="0.2" altitude_max="100.0"/>
      <noise velocity="0.005" altitude="0.01"/>
      <ros_publisher topic="/chatboat/dvl"/>
    </sensor>

    <sensor name="gps" type="gps" rate="1.0">
      <link name="base_link"/>
      <origin xyz="0.0 0.0 -0.15" rpy="0.0 0.0 0.0"/>
      <noise ned_position="0.5"/>
      <ros_publisher topic="/chatboat/gps"/>
    </sensor>

    <!-- Forward camera -->
    <sensor name="camera_front" type="camera" rate="15.0">
      <link name="base_link"/>
      <origin xyz="0.16 0.0 0.0" rpy="1.5708 0.0 1.5708"/>
      <specs resolution_x="640" resolution_y="480" horizontal_fov="70.0"/>
      <ros_publisher topic="/chatboat/camera_front"/>
    </sensor>

    <!-- Arm sensors -->
    <sensor name="ft_wrist" type="forcetorque" rate="100.0">
      <joint name="axis_b"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <noise force="0.1" torque="0.01"/>
      <ros_publisher topic="/chatboat/ft_wrist"/>
    </sensor>

    <sensor name="ee_camera" type="camera" rate="15.0">
      <link name="gripper_tip"/>
      <origin xyz="0.0 0.0 -0.02" rpy="0.0 1.5708 0.0"/>
      <specs resolution_x="640" resolution_y="480" horizontal_fov="70.0"/>
      <ros_publisher topic="/chatboat/ee_camera"/>
    </sensor>

    <!-- Joint encoders -->
    <sensor name="encoder_e" type="encoder" rate="100.0">
      <joint name="axis_e"/>
      <ros_publisher topic="/chatboat/joint_states"/>
    </sensor>
    <sensor name="encoder_d" type="encoder" rate="100.0">
      <joint name="axis_d"/>
      <ros_publisher topic="/chatboat/joint_states"/>
    </sensor>
    <sensor name="encoder_c" type="encoder" rate="100.0">
      <joint name="axis_c"/>
      <ros_publisher topic="/chatboat/joint_states"/>
    </sensor>
    <sensor name="encoder_b" type="encoder" rate="100.0">
      <joint name="axis_b"/>
      <ros_publisher topic="/chatboat/joint_states"/>
    </sensor>

    <!-- ============================================================== -->
    <!-- ROS2 TOPIC WIRING                                              -->
    <!-- ============================================================== -->
    <ros_subscriber thrusters="/chatboat/thruster_commands" servos="/chatboat/joint_commands"/>

    <!-- Initial position: 2m depth, centered -->
    <world_transform xyz="0.0 0.0 2.0" rpy="0.0 0.0 0.0"/>
  </robot>

</scenario>

<?xml version="1.0"?>
<!-- GIRONA500 UVMS: vehicle + ECA 5E arm + magnetic gripper for Stonefish -->
<robot name="girona500" fixed="false" self_collisions="false">

  <!-- ==================== VEHICLE BODY ==================== -->

  <!-- Compound base_link: 3 torpedo hulls -->
  <base_link name="base_link" type="compound">
    <!-- Upper port hull (foam) -->
    <external_part name="hull_upper_port" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.15" length="1.5"/>
      <origin xyz="0.0 -0.22 -0.12" rpy="0.0 1.5708 0.0"/>
      <material name="Foam"/>
      <mass value="15.0"/>
      <look name="yellow"/>
    </external_part>
    <!-- Upper starboard hull (foam) -->
    <external_part name="hull_upper_stbd" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.15" length="1.5"/>
      <origin xyz="0.0 0.22 -0.12" rpy="0.0 1.5708 0.0"/>
      <material name="Foam"/>
      <mass value="15.0"/>
      <look name="yellow"/>
    </external_part>
    <!-- Lower hull (aluminium) -->
    <external_part name="hull_lower" type="cylinder" physics="submerged" buoyant="true">
      <dimensions radius="0.15" length="1.5"/>
      <origin xyz="0.0 0.0 0.17" rpy="0.0 1.5708 0.0"/>
      <material name="Aluminium"/>
      <mass value="110.0"/>
      <look name="grey"/>
    </external_part>
  </base_link>

  <!-- ==================== MANIPULATOR ARM ==================== -->

  <!-- Arm base (fixed to vehicle front-bottom) -->
  <link name="arm_base" type="cylinder" physics="submerged" buoyant="true">
    <dimensions radius="0.04" length="0.05"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="Aluminium"/>
    <mass value="0.5"/>
    <look name="black"/>
  </link>
  <joint name="arm_base_joint" type="fixed">
    <parent name="base_link"/>
    <child name="arm_base"/>
    <origin xyz="0.75 0.0 0.15" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Link 1: Shoulder yaw -->
  <link name="arm_link1" type="cylinder" physics="submerged" buoyant="true">
    <dimensions radius="0.035" length="0.10"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="Aluminium"/>
    <mass value="0.4"/>
    <look name="black"/>
  </link>
  <joint name="q1_shoulder_yaw" type="revolute">
    <parent name="arm_base"/>
    <child name="arm_link1"/>
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limits min="-3.14" max="3.14"/>
  </joint>

  <!-- Link 2: Shoulder pitch -->
  <link name="arm_link2" type="cylinder" physics="submerged" buoyant="true">
    <dimensions radius="0.030" length="0.20"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 1.5708 0.0"/>
    <material name="Aluminium"/>
    <mass value="0.6"/>
    <look name="orange"/>
  </link>
  <joint name="q2_shoulder_pitch" type="revolute">
    <parent name="arm_link1"/>
    <child name="arm_link2"/>
    <origin xyz="0.0 0.0 0.10" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limits min="-1.57" max="1.57"/>
  </joint>

  <!-- Link 3: Elbow pitch -->
  <link name="arm_link3" type="cylinder" physics="submerged" buoyant="true">
    <dimensions radius="0.025" length="0.20"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 1.5708 0.0"/>
    <material name="Aluminium"/>
    <mass value="0.5"/>
    <look name="orange"/>
  </link>
  <joint name="q3_elbow_pitch" type="revolute">
    <parent name="arm_link2"/>
    <child name="arm_link3"/>
    <origin xyz="0.20 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limits min="-2.36" max="2.36"/>
  </joint>

  <!-- Link 4: Wrist pitch -->
  <link name="arm_link4" type="cylinder" physics="submerged" buoyant="true">
    <dimensions radius="0.025" length="0.10"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 1.5708 0.0"/>
    <material name="Aluminium"/>
    <mass value="0.3"/>
    <look name="black"/>
  </link>
  <joint name="q4_wrist_pitch" type="revolute">
    <parent name="arm_link3"/>
    <child name="arm_link4"/>
    <origin xyz="0.20 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limits min="-2.36" max="2.36"/>
  </joint>

  <!-- Gripper tip (permanent magnet) -->
  <link name="gripper_tip" type="sphere" physics="submerged" buoyant="true">
    <dimensions radius="0.03"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="PermanentMagnet"/>
    <mass value="0.2"/>
    <look name="red"/>
  </link>
  <joint name="gripper_tip_joint" type="fixed">
    <parent name="arm_link4"/>
    <child name="gripper_tip"/>
    <origin xyz="0.10 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- EE frame -->
  <link name="ee_frame" type="sphere" physics="surface" buoyant="false">
    <dimensions radius="0.005"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <material name="Neutral"/>
    <mass value="0.001"/>
    <look name="red"/>
  </link>
  <joint name="ee_frame_joint" type="fixed">
    <parent name="gripper_tip"/>
    <child name="ee_frame"/>
    <origin xyz="0.03 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- ==================== THRUSTERS ==================== -->

  <!-- T1: Surge port -->
  <actuator name="thruster_surge_port" type="thruster">
    <link name="base_link"/>
    <origin xyz="-0.75 -0.30 0.0" rpy="0.0 0.0 0.0"/>
    <specs thrust_coeff="0.4472" torque_coeff="0.01" max_rpm="3000"/>
    <propeller diameter="0.08" right="true">
      <mesh filename="propeller.obj" scale="1.0"/>
      <material name="Neutral"/>
      <look name="white"/>
    </propeller>
  </actuator>

  <!-- T2: Surge starboard -->
  <actuator name="thruster_surge_stbd" type="thruster">
    <link name="base_link"/>
    <origin xyz="-0.75 0.30 0.0" rpy="0.0 0.0 0.0"/>
    <specs thrust_coeff="0.4472" torque_coeff="0.01" max_rpm="3000"/>
    <propeller diameter="0.08" right="true">
      <mesh filename="propeller.obj" scale="1.0"/>
      <material name="Neutral"/>
      <look name="white"/>
    </propeller>
  </actuator>

  <!-- T3: Sway -->
  <actuator name="thruster_sway" type="thruster">
    <link name="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 1.5708"/>
    <specs thrust_coeff="0.4472" torque_coeff="0.01" max_rpm="3000"/>
    <propeller diameter="0.08" right="true">
      <mesh filename="propeller.obj" scale="1.0"/>
      <material name="Neutral"/>
      <look name="white"/>
    </propeller>
  </actuator>

  <!-- T4: Heave port -->
  <actuator name="thruster_heave_port" type="thruster">
    <link name="base_link"/>
    <origin xyz="0.0 -0.30 0.0" rpy="0.0 -1.5708 0.0"/>
    <specs thrust_coeff="0.4472" torque_coeff="0.01" max_rpm="3000"/>
    <propeller diameter="0.08" right="true">
      <mesh filename="propeller.obj" scale="1.0"/>
      <material name="Neutral"/>
      <look name="white"/>
    </propeller>
  </actuator>

  <!-- T5: Heave starboard -->
  <actuator name="thruster_heave_stbd" type="thruster">
    <link name="base_link"/>
    <origin xyz="0.0 0.30 0.0" rpy="0.0 -1.5708 0.0"/>
    <specs thrust_coeff="0.4472" torque_coeff="0.01" max_rpm="3000"/>
    <propeller diameter="0.08" right="true">
      <mesh filename="propeller.obj" scale="1.0"/>
      <material name="Neutral"/>
      <look name="white"/>
    </propeller>
  </actuator>

  <!-- ==================== SERVO ACTUATORS ==================== -->

  <actuator name="servo_q1" type="servo">
    <joint name="q1_shoulder_yaw"/>
    <controller position_gain="1.0" velocity_gain="0.5" max_torque="20.0"/>
  </actuator>
  <actuator name="servo_q2" type="servo">
    <joint name="q2_shoulder_pitch"/>
    <controller position_gain="1.0" velocity_gain="0.5" max_torque="20.0"/>
  </actuator>
  <actuator name="servo_q3" type="servo">
    <joint name="q3_elbow_pitch"/>
    <controller position_gain="0.8" velocity_gain="0.4" max_torque="15.0"/>
  </actuator>
  <actuator name="servo_q4" type="servo">
    <joint name="q4_wrist_pitch"/>
    <controller position_gain="0.8" velocity_gain="0.4" max_torque="10.0"/>
  </actuator>

  <!-- ==================== SENSORS ==================== -->

  <!-- IMU -->
  <sensor name="imu" type="imu" rate="100.0">
    <link name="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <noise angle="0.01" angular_velocity="0.001" linear_acceleration="0.01"/>
    <ros_publisher topic="/girona500/imu"/>
  </sensor>

  <!-- DVL -->
  <sensor name="dvl" type="dvl" rate="10.0">
    <link name="base_link"/>
    <origin xyz="0.0 0.0 0.20" rpy="0.0 0.0 0.0"/>
    <specs beam_angle="30.0"/>
    <noise velocity="0.005" altitude="0.01"/>
    <ros_publisher topic="/girona500/dvl"/>
  </sensor>

  <!-- Pressure sensor -->
  <sensor name="pressure" type="pressure" rate="10.0">
    <link name="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <noise pressure="100.0"/>
    <ros_publisher topic="/girona500/pressure"/>
  </sensor>

  <!-- GPS (for surface initialization) -->
  <sensor name="gps" type="gps" rate="1.0">
    <link name="base_link"/>
    <origin xyz="0.0 0.0 -0.20" rpy="0.0 0.0 0.0"/>
    <noise ned_position="0.5"/>
    <ros_publisher topic="/girona500/gps"/>
  </sensor>

  <!-- Odometry (noisy ground truth) -->
  <sensor name="odometry" type="odometry" rate="50.0">
    <link name="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <noise position="0.01" velocity="0.005" angle="0.005" angular_velocity="0.002"/>
    <ros_publisher topic="/girona500/odometry"/>
  </sensor>

  <!-- Wrist force-torque sensor -->
  <sensor name="ft_wrist" type="forcetorque" rate="100.0">
    <joint name="q4_wrist_pitch"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <noise force="0.1" torque="0.01"/>
    <ros_publisher topic="/girona500/ft_wrist"/>
  </sensor>

  <!-- End-effector camera -->
  <sensor name="ee_camera" type="camera" rate="15.0">
    <link name="gripper_tip"/>
    <origin xyz="0.0 0.0 -0.02" rpy="0.0 1.5708 0.0"/>
    <specs resolution_x="640" resolution_y="480" horizontal_fov="70.0"/>
    <ros_publisher topic="/girona500/ee_camera"/>
  </sensor>

  <!-- Joint encoders (published as aggregate joint_states) -->
  <sensor name="encoder_q1" type="encoder" rate="100.0">
    <joint name="q1_shoulder_yaw"/>
    <ros_publisher topic="/girona500/joint_states"/>
  </sensor>
  <sensor name="encoder_q2" type="encoder" rate="100.0">
    <joint name="q2_shoulder_pitch"/>
    <ros_publisher topic="/girona500/joint_states"/>
  </sensor>
  <sensor name="encoder_q3" type="encoder" rate="100.0">
    <joint name="q3_elbow_pitch"/>
    <ros_publisher topic="/girona500/joint_states"/>
  </sensor>
  <sensor name="encoder_q4" type="encoder" rate="100.0">
    <joint name="q4_wrist_pitch"/>
    <ros_publisher topic="/girona500/joint_states"/>
  </sensor>

  <!-- ==================== ROS2 SUBSCRIBERS ==================== -->

  <ros_subscriber topic="/girona500/thruster_commands" type="std_msgs/Float64MultiArray">
    <actuator name="thruster_surge_port" index="0"/>
    <actuator name="thruster_surge_stbd" index="1"/>
    <actuator name="thruster_sway" index="2"/>
    <actuator name="thruster_heave_port" index="3"/>
    <actuator name="thruster_heave_stbd" index="4"/>
  </ros_subscriber>

  <ros_subscriber topic="/girona500/joint_commands" type="sensor_msgs/JointState">
    <actuator name="servo_q1"/>
    <actuator name="servo_q2"/>
    <actuator name="servo_q3"/>
    <actuator name="servo_q4"/>
  </ros_subscriber>

  <!-- Spawn position -->
  <world_transform xyz="0.0 0.0 2.0" rpy="0.0 0.0 0.0"/>

</robot>
